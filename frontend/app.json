{
  "expo": {
    "name": "ExamVault",
    "slug": "examvault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "examvault",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emergent.trustpapers.qkojz0"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.emergent.trustpapers.qkojz0"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "ExamVault — Restoring Trust in High-Stakes Examinations",
      "shortName": "ExamVault",
      "description": "A Zero-Trust Digital Examination Infrastructure powered by AI, Blockchain and Cryptography.",
      "themeColor": "#0F172A",
      "backgroundColor": "#0F172A",
      "lang": "en"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F172A"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
