{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "yarn install --frozen-lockfile && npx expo export --platform web",
  "outputDirectory": "dist",
  "installCommand": "yarn install --frozen-lockfile",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/verify/:id", "destination": "/verify/[id].html" }
  ]
}
